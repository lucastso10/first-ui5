<mvc:View
  controllerName="ui5.first.controller.TablePanel"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc">

<Table id="idTimesTable" items="{/Submissions}">
  <headerToolbar>
    <OverflowToolbar id="otbSubheader">
      <Title text="Myte" level="H2" />
      <ToolbarSpacer />
      <Button id="addButton" text="{i18n>addButton}" type="Transparent"
	press=".onAdd" />
      <Button id="editButton" text="{i18n>editButton}" type="Transparent"
	press=".onEdit" />
      <Button id="saveButton" text="{i18n>saveButton}" type="Transparent"
	press=".onSave" visible="false" />
    </OverflowToolbar>
  </headerToolbar>
  <columns>
    <Column>
      <Text text="WBS" />
    </Column>
    <Column>
      <Text text="Dia 1" />
    </Column>
    <Column>
      <Text text="Dia 2" />
    </Column>
    <Column>
      <Text text="Dia 3" />
    </Column>
    <Column>
      <Text text="Dia 4" />
    </Column>
    <Column>
      <Text text="Dia 5" />
    </Column>
    <Column>
      <Text text="Dia 6" />
    </Column>
    <Column>
      <Text text="Dia 7" />
    </Column>
    <Column>
      <Text text="Dia 8" />
    </Column>
    <Column>
      <Text text="Dia 9" />
    </Column>
    <Column>
      <Text text="Dia 10" />
    </Column>
    <Column>
      <Text text="Dia 11" />
    </Column>
    <Column>
      <Text text="Dia 12" />
    </Column>
    <Column>
      <Text text="Dia 13" />
    </Column>
    <Column>
      <Text text="Dia 14" />
    </Column>
    <Column>
      <Text text="Dia 15" />
    </Column>
  </columns>
  <items>
    <ColumnListItem id="idTimesTableColumns" vAlign="Middle">
      <cells>
	<ObjectIdentifier title="{WBS}" />
	<ObjectNumber number="{day1}" state="{= ${day1} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day2}" state="{= ${day2} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day3}" state="{= ${day3} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day4}" state="{= ${day4} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day5}" state="{= ${day5} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day6}" state="{= ${day6} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day7}" state="{= ${day7} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day8}" state="{= ${day8} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day9}" state="{= ${day9} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day10}" state="{= ${day10} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day11}" state="{= ${day11} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day12}" state="{= ${day12} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day13}" state="{= ${day13} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day14}" state="{= ${day14} > 8 ? 'Error' : 'None'}"/>
	<ObjectNumber number="{day15}" state="{= ${day15} > 8 ? 'Error' : 'None'}"/>
      </cells>
    </ColumnListItem>
  </items>
</Table>

<OverflowToolbar>
  <ToolbarSpacer />
  <Button
    text="Submit"
    press=".onSubmitFinal"
    type="Emphasized"/>
</OverflowToolbar>
</mvc:View>
